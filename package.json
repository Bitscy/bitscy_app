{
  "name": "bitscy",
  "version": "0.1.0",
  "private": true,
  "description": "A Bitcoin-native marketplace for African creative women",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "@breeztech/breez-sdk-liquid": "0.9.2-rc1",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@prisma/client": "^5.22.0",
    "browser-image-compression": "^2.0.2",
    "cloudinary": "^2.5.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "16.2.6",
    "nostr-tools": "^2.23.3",
    "qrcode.react": "^4.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "swr": "^2.3.0",
    "tailwind-merge": "^2.6.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.10.5",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.2",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.15",
      "@types/react-dom": "19.2.3"
    }
  }
}
