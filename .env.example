# Copy this file to .env.local and fill in actual values.
# Never commit .env.local

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/bitscy"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Breez SDK Spark ───────────────────────────────────────────────────────────
# Get your API key at https://breez.technology
BREEZ_API_KEY=""

# "mainnet" for production, "signet" for staging/testing
BREEZ_NETWORK="mainnet"

# Persistent volume path on the server. Each seller wallet is at $BREEZ_STORAGE_DIR/<sellerId>.
# Must survive server restarts — mount a volume at /data and set this to /data/bitscy-wallets.
# Not used when USE_MOCK_LIGHTNING=true.
BREEZ_STORAGE_DIR="/data/bitscy-wallets"

# Shared HMAC secret for verifying Breez webhook signatures.
# Generate with: openssl rand -hex 32
BREEZ_WEBHOOK_SECRET=""

# "true" for local dev without a Breez API key. "false" on the server with BREEZ_API_KEY set.
USE_MOCK_LIGHTNING="true"

# ── Nostr ─────────────────────────────────────────────────────────────────────
# Server-side signing key (bech32 nsec). Used to sign order Nostr events.
# Generate: node -e "const {generateSecretKey,nsecEncode}=require('nostr-tools/pure');console.log(nsecEncode(generateSecretKey()))"
SYSTEM_NSEC=""
NEXT_PUBLIC_NOSTR_RELAYS="wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net,wss://nostr.wine"

# ── Demo / pricing ────────────────────────────────────────────────────────────
DEMO_BTC_NGN_RATE="145000000"
PLATFORM_FEE_PERCENT="2"

# ── Web Push ──────────────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC=""
WEB_PUSH_VAPID_PRIVATE=""
WEB_PUSH_VAPID_SUBJECT="mailto:team@bitscy.com"
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC=""

# ── Session ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=""

# ── Bitnob (naira off-ramp) ───────────────────────────────────────────────────
# Sign up at https://app.bitnob.co/accounts/signup
# Your credentials are on the API Settings page of your Bitnob dashboard.
# Sandbox and production share the same CLIENT_ID; the SECRET_KEY differs per environment.
BITNOB_CLIENT_ID=""
BITNOB_CLIENT_SECRET=""
# Set to "true" once you have real Bitnob credentials and are ready to go live.
USE_REAL_BITNOB="false"
