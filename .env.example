# Copy this file to .env.local and fill in actual values
# Never commit .env.local

# Database
DATABASE_URL="postgresql://user:password@host:5432/bitscy"

# Public app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Breez SDK
BREEZ_API_KEY=""
BREEZ_NETWORK="signet"

# Nostr
SYSTEM_NSEC=""
NEXT_PUBLIC_NOSTR_RELAYS="wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net,wss://nostr.wine"

# Demo settings
DEMO_BTC_NGN_RATE="145000000"
PLATFORM_FEE_PERCENT="2"

# Web Push (generate with: npx web-push generate-vapid-keys)
WEB_PUSH_VAPID_PUBLIC=""
WEB_PUSH_VAPID_PRIVATE=""
WEB_PUSH_VAPID_SUBJECT="mailto:team@bitscy.com"
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC=""

# Session
SESSION_SECRET=""
